generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// --- MULTI-ENTITY & AUTH ---

model Organization {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  entities    Entity[]
}

model Entity {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  baseCurrency   String   // e.g., USD
  isElimination  Boolean  @default(false) // True for consolidation elimination entities
  organization   Organization @relation(fields: [organizationId], references: [id])
  accounts       Account[]
  journalEntries JournalEntry[]
  contacts       Contact[]
  invoices       Invoice[]
  bills          Bill[]
  bankAccounts   BankAccount[]
}

// --- ACCOUNTING ENGINE ---

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model Account {
  id          String      @id @default(cuid())
  entityId    String
  code        String      // e.g., "1000"
  name        String      // e.g., "Cash"
  type        AccountType
  isControl   Boolean     @default(false) // True for AR, AP, Inventory (blocks manual journals)
  isActive    Boolean     @default(true)
  entity      Entity      @relation(fields: [entityId], references: [id])
  lines       JournalLine[]
  invoiceLines InvoiceLine[]
  billLines    BillLine[]
  bankAccount  BankAccount?

  @@unique([entityId, code])
}

enum EntryStatus {
  DRAFT
  POSTED
  VOIDED
}

model JournalEntry {
  id          String        @id @default(cuid())
  entityId    String
  date        DateTime
  description String
  status      EntryStatus   @default(DRAFT)
  sourceType  String        // e.g., "INVOICE", "BILL", "MANUAL", "STOCK_RECEIPT"
  sourceId    String?       // ID of the source document
  createdAt   DateTime      @default(now())
  createdBy   String
  entity      Entity        @relation(fields: [entityId], references: [id])
  lines       JournalLine[]
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  description    String?
  debit          Decimal      @default(0)
  credit         Decimal      @default(0)
  contactId      String?      // Link to Customer/Vendor for AR/AP subledgers
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id])
  contact        Contact?     @relation(fields: [contactId], references: [id])
  bankTransaction BankTransaction?
}

// --- SUBLEDGERS & CONTACTS ---

enum ContactType {
  CUSTOMER
  VENDOR
  BOTH
}

model Contact {
  id          String   @id @default(cuid())
  entityId    String
  name        String
  type        ContactType
  email       String?
  phone       String?
  createdAt   DateTime @default(now())
  entity      Entity   @relation(fields: [entityId], references: [id])
  invoices    Invoice[]
  bills       Bill[]
  journalLines JournalLine[]
}

enum DocumentStatus {
  DRAFT
  AUTHORISED
  PAID
  VOIDED
}

model Invoice {
  id            String   @id @default(cuid())
  entityId      String
  contactId     String
  date          DateTime
  dueDate       DateTime
  invoiceNumber String
  status        DocumentStatus @default(DRAFT)
  totalAmount   Decimal  @default(0)
  createdAt     DateTime @default(now())
  entity        Entity   @relation(fields: [entityId], references: [id])
  contact       Contact  @relation(fields: [contactId], references: [id])
  lines         InvoiceLine[]
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  accountId   String
  description String?
  quantity    Decimal  @default(1)
  unitPrice   Decimal  @default(0)
  amount      Decimal  @default(0)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  account     Account  @relation(fields: [accountId], references: [id])
}

model Bill {
  id          String   @id @default(cuid())
  entityId    String
  contactId   String
  date        DateTime
  dueDate     DateTime
  billNumber  String
  status      DocumentStatus @default(DRAFT)
  totalAmount Decimal  @default(0)
  createdAt   DateTime @default(now())
  entity      Entity   @relation(fields: [entityId], references: [id])
  contact     Contact  @relation(fields: [contactId], references: [id])
  lines       BillLine[]
}

model BillLine {
  id          String   @id @default(cuid())
  billId      String
  accountId   String
  description String?
  quantity    Decimal  @default(1)
  unitPrice   Decimal  @default(0)
  amount      Decimal  @default(0)
  bill        Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  account     Account  @relation(fields: [accountId], references: [id])
}

// --- BANKING & RECONCILIATION ---

model BankAccount {
  id            String   @id @default(cuid())
  entityId      String
  accountId     String   @unique // The GL account this bank account maps to
  name          String
  accountNumber String?
  bankName      String?
  currency      String   @default("USD")
  createdAt     DateTime @default(now())
  entity        Entity   @relation(fields: [entityId], references: [id])
  account       Account  @relation(fields: [accountId], references: [id])
  transactions  BankTransaction[]
}

enum BankTransactionStatus {
  UNRECONCILED
  RECONCILED
}

model BankTransaction {
  id              String   @id @default(cuid())
  bankAccountId   String
  date            DateTime
  description     String
  amount          Decimal  // Positive = money in, Negative = money out
  status          BankTransactionStatus @default(UNRECONCILED)
  matchedLineId   String?  @unique // The journal line this is reconciled against
  createdAt       DateTime @default(now())
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  matchedLine     JournalLine? @relation(fields: [matchedLineId], references: [id])
}
